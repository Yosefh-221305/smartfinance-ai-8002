# SmartFinance AI — Environment Variables
# Salin file ini: cp .env.example .env
# Lalu isi nilai sesuai konfigurasi kamu

# ── LLM API Keys ───────────────────────────────────────────────────────────
# Dapatkan Groq API key gratis di: https://console.groq.com
# JANGAN commit file .env ke Git — tambahkan .env ke .gitignore
GROQ_API_KEY=your_groq_api_key_here

# ── Auth & Security ─────────────────────────────────────────────────────────
# API key untuk melindungi endpoint Python API dari akses tidak sah
# Kosongkan untuk dev mode (tanpa auth)
SMARTFINANCE_API_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── URL Antar API ────────────────────────────────────────────────────────────
RECOMMENDATION_API_URL=http://localhost:8001
CLASSIFY_API_URL=http://localhost:8002

# ── Database (untuk postgres_bridge.py) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartfinance_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
